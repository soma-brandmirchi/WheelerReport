# Base URL of the Wheeler Adconnect API (no trailing slash, no /api suffix)
WHEELER_API_BASE_URL=https://wheeleradconnect.com

# Set to true if Node fetch fails TLS verification against the upstream host.
WHEELER_API_INSECURE_TLS=true

# Credentials used to obtain a bearer token from /api/login (OAuth2 password flow).
# Leave blank if your endpoints don't require auth.
WHEELER_API_USERNAME=
WHEELER_API_PASSWORD=
